# Formata a tabela de acordo com o formato de saída.
# - HTML : tabela estilizada (bootstrap + cores institucionais)
# - Word : tabela NATIVA do Word (kable_styling com cores é HTML e quebra no docx)
# - PDF  : tabela LaTeX com booktabs
formatar_tabela <- function(tabela, legenda) {
  alinhamento <- c("l", rep("c", ncol(tabela) - 1))

  if (is_html) {
    kable(tabela, caption = legenda, align = alinhamento) %>%
      kable_styling(
        bootstrap_options = c("striped", "hover", "condensed", "responsive"),
        full_width = TRUE
      ) %>%
      row_spec(0, background = "#1B5E20", color = "white", bold = TRUE) %>%
      row_spec(nrow(tabela), bold = TRUE, background = "#C8E6C9")
  } else if (is_latex) {
    kable(tabela, caption = legenda, align = alinhamento, booktabs = TRUE) %>%
      kable_styling(latex_options = c("striped", "hold_position"))
  } else {
    # Word (docx) e demais: tabela nativa, sem estilo HTML
    kable(tabela, caption = legenda, align = alinhamento)
  }
}
