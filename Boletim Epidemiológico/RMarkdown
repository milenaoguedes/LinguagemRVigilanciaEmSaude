```{r grafico-idade-atualizado, fig.cap=" "}
# Carrega os pacotes necessários para garantir a reprodutibilidade
library(ggplot2)
library(dplyr)

# Definição da paleta de cores institucional para as faixas etárias
paleta_idade <- c(
  "10 a 14 anos" = "#91e8e1", 
  "15 a 19 anos" = "#8085e8",
  "20 a 29 anos" = "#e4d354", 
  "30 a 39 anos" = "#f15c80",  
  "40 a 49 anos" = "#f7a35c",
  "50 a 59 anos" = "#90ed7d"  
)

# Construção do gráfico de distribuição proporcional empilhado
ggplot(dados_proporcao_idade, aes(x = factor(ANO_BANCO), y = Porcentagem, fill = Faixa_Etaria)) +
  # Criação das colunas empilhadas com bordas brancas para melhor delimitação visual
  geom_col(position = position_stack(rev = TRUE), width = 0.55, color = "white", linewidth = 0.3) +
  
  # ADAPTAÇÃO: Remoção do filtro 'Porcentagem > 2' para exibir todas as faixas e redução do 'size'
  geom_text(
    aes(label = paste0(format(round(Porcentagem, 1), nsmall = 1, decimal.mark = ","), "%")),
    position = position_stack(vjust = 0.5, rev = TRUE),
    size = 2.8,          # Reduzido de 3.2 para 2.8 para caber em fatias menores
    color = "black",     # Alterado para preto para garantir contraste em fundos muito claros (como o #91e8e1)
    fontface = "bold"
  ) +
  
  # Escalas e formatações de eixos
  scale_fill_manual(values = paleta_idade, name = NULL) +
  scale_y_continuous(labels = function(x) paste0(x, "%")) +
  
  # Rótulos textuais e notas de rodapé essenciais para a Vigilância
  labs(
    x = NULL, 
    y = "Proporção (%)", 
    caption = "DATASUS, Sinan - Dados provisórios sujeitos à atualização e extraídos em 02/05/2026."
  ) +
  
  # Aplicação do tema minimalista institucional
  theme_minimal(base_size = 12) +
  theme(
    plot.caption       = element_text(color = "#777", size = 8, hjust = 1),
    legend.position    = "bottom",
    legend.text        = element_text(size = 9),
    panel.grid.major.x = element_blank(),
    panel.grid.minor   = element_blank(),
    axis.text.x        = element_text(face = "bold", size = 11)
  ) +
  # Organização da legenda em duas linhas para não comprometer a largura útil da página HTML
  guides(fill = guide_legend(nrow = 2, byrow = TRUE))
```


